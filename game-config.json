  "engine_candidates": [
    {
      "name": "Godot",
      "language": "GDScript",
      "pros": [
        "2D-first design perfectly suited for tower defense",
        "Free and open-source with no licensing concerns",
        "Strongly deterministic physics and behavior (critical for balance tuning)",
        "Python-like GDScript lowers entry barrier",
        "Excellent built-in narrative/cutscene tooling for campaign content",
        "Active indie game community with tower defense expertise"
      ],
      "cons": [
        "Smaller asset store compared to Unity (fewer pre-built tower defense templates)",
        "Younger engine with fewer established enterprise patterns",
        "Smaller networking ecosystem for future multiplayer expansion"
      ],
      "fit_score": 0.82,
      "links": [
        "https://godotengine.org/",
        "https://docs.godotengine.org/en/stable/community/index.html"
      ]
    },
    {
      "name": "Unity",
      "language": "C#",
      "pros": [
        "Massive asset store with pre-built tower defense systems and templates",
        "Industry-standard UI system handles resource management and campaign menus well",
        "Netcode for GameObjects and Mirror enable future multiplayer/online features",
        "Extensive documentation and tutorial coverage for tower defense patterns",
        "Proven track record in commercial tower defense titles"
      ],
      "cons": [
        "Licensing and pricing controversy may impact long-term viability",
        "Engine is heavyweight for 2D tower defense scope",
        "Larger binary footprint than purpose-built 2D engines",
        "C# learning curve steeper than scripting languages"
      ],
      "fit_score": 0.78,
      "links": [
        "https://unity.com/",
        "https://docs.unity3d.com/2023.2/Documentation/Manual/index.html"
      ]
    },
    {
      "name": "Defold",
      "language": "Lua",
      "pros": [
        "Purpose-built for 2D; no bloat from 3D features",
        "Strongly deterministic for balance tuning and competitive play",
        "Lightweight engine with excellent performance on campaign maps with swarms",
        "Lua scripting enables rapid iteration on game mechanics and AI",
        "Proven in production tower defense and strategy games",
        "Cloud-based tooling reduces setup burden"
      ],
      "cons": [
        "Smaller third-party community and fewer pre-built systems",
        "Fewer narrative/campaign template resources than mainstream engines",
        "Documentation less comprehensive than Unity/Unreal"
      ],
      "fit_score": 0.75,
      "links": [
        "https://defold.com/",
        "https://defold.com/manuals/introduction/"
      ]
    },
    {
      "name": "Phaser",
      "language": "JavaScript/TypeScript",
      "pros": [
        "Web-first deployment for immediate player accessibility",
        "Fast prototyping cycle with hot reload",
        "TypeScript support enables type safety for complex game logic",
        "Mature asset pipeline for tower defense visuals",
        "Lower barrier to entry for web developers"
      ],
      "cons": [
        "Web-only deployment limits platform reach (no native mobile)",
        "Networking complexity greater than purpose-built engines",
        "Campaign progression UX more manual to implement",
        "Determinism harder to guarantee across browsers"
      ],
      "fit_score": 0.65,
      "links": [
        "https://phaser.io/",
        "https://phaser.io/documentation"
      ]
    }
  ],
  "chosen_engine": {
    "name": "Bevy",
    "language": "Rust",
    "selected_from": "engine_candidates[1]",
    "selected_on": "2026-05-19",
    "networking_model": "deterministic lockstep",
    "architecture": "fixed-tick sim (20-30Hz) decoupled from interpolated render tick; only inputs cross the wire",
    "notes": "Determinism rules are binding on all Phase 2 sim-path code. See CLAUDE.md > 'Target engine' for the full rule set.",
    "module_registration": {
      "aggregator": "{dir}/mod.rs",
      "declaration": "pub mod {stem};"
    }
