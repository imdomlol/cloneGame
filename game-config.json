  "engine_candidates": [
    {
      "name": "Godot",
      "language": "GDScript (Python-like)",
      "pros": [
        "Deterministic 2D tower-defense ideal; free and open-source",
        "GDScript philosophy aligns with Python data-ingest pipeline",
        "Native wave-spawning and unit pathfinding support",
        "Data-driven; frontmatter→scene graph mapping is natural",
        "Single-player focus avoids multiplayer complexity"
      ],
      "cons": [
        "Smaller ecosystem than Unity; fewer pre-built tower-defense assets",
        "C++ backend less familiar to typical game modders"
      ],
      "fit_score": 0.87,
      "links": [
        "https://godotengine.org",
        "https://docs.godotengine.org/en/stable/getting_started/introduction/index.html"
      ]
    },
    {
      "name": "Unity",
      "language": "C#",
      "pros": [
        "Industry standard; large tower-defense template ecosystem",
        "Robust UI (building menus, research trees) and animation systems",
        "Deterministic tick-based simulation; proven wave mechanics",
        "Asset store for infected rigs, building meshes, audio"
      ],
      "cons": [
        "Licensing friction above revenue threshold (>$1M ARR)",
        "Editor overhead; more learning curve than Godot for this scope"
      ],
      "fit_score": 0.81,
      "links": [
        "https://unity.com",
        "https://docs.unity3d.com/Manual/index.html"
      ]
    },
    {
      "name": "Phaser 3",
      "language": "TypeScript/JavaScript",
      "pros": [
        "Web-native deployment; rapid iteration from wiki data → playable",
        "Strong 2D (isometric tower defense fits naturally)",
        "Lightweight; deterministic event scheduling for waves",
        "Declarative JSON config integrates cleanly with game-config.json"
      ],
      "cons": [
        "Performance ceiling on large infected counts (28+ simultaneous)",
        "Mobile performance unpredictable; no native mobile SDKs"
      ],
      "fit_score": 0.74,
      "links": [
        "https://phaser.io",
        "https://newdocs.phaser.io/docs/3.60.0"
      ]
    },
    {
      "name": "Monogame",
      "language": "C#",
      "pros": [
        "Lightweight XNA-style framework; low overhead for tower defense",
        "Deterministic 2D simulation; cross-platform (Windows/macOS/Linux)",
        "Data-driven architecture; good for code-generated game logic"
      ],
      "cons": [
        "Minimal built-in UI; research trees and menus require custom code",
        "Smaller community; fewer pathfinding plugins vs. Unity"
      ],
      "fit_score": 0.7,
      "links": [
        "https://www.monogame.net",
        "https://docs.monogame.net"
      ]
    }
  ],
  "chosen_engine": {
    "name": "Bevy",
    "language": "Rust",
    "selected_from": "engine_candidates[1]",
    "selected_on": "2026-05-19",
    "networking_model": "deterministic lockstep",
    "architecture": "fixed-tick sim (20-30Hz) decoupled from interpolated render tick; only inputs cross the wire",
    "notes": "Determinism rules are binding on all Phase 2 sim-path code. See CLAUDE.md > 'Target engine' for the full rule set."
  }
