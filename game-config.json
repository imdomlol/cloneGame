{
  "version": 1,
  "game": {
    "name": "They Are Billions",
    "wiki_base_url": "https://they-are-billions.fandom.com/wiki/"
  },
  "human_approved": true,
  "phase0_notes": "Kinds below are the deployment-guide §1.3 taxonomy seeded as a baseline. A future Phase 0 taxonomy-discovery LLM should propose a game-specific refinement of this list, and a human must flip `human_approved` to true before Phase 1 ingest runs in production.",
  "defaultKind": "concept",
  "kinds": {
    "building": {
      "minWikilinks": 1,
      "description": "A constructed structure with stats, cost, requirements, and effects as required frontmatter fields."
    },
    "unit": {
      "minWikilinks": 2,
      "description": "A controllable hero or unit with stats, abilities, progression, and requirements as required frontmatter fields."
    },
    "enemy": {
      "minWikilinks": 2,
      "description": "A hostile creature with stats, loot_table, ai_profile, and resistances as required frontmatter fields.",
      "frontmatter_schema": {
        "required": [
          "stats",
          "loot_table",
          "ai_profile",
          "resistances"
        ],
        "properties": {
          "stats": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "integer"
              ]
            }
          },
          "loot_table": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "chance"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "chance": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "min": {
                  "type": "integer",
                  "minimum": 0
                },
                "max": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "ai_profile": {
            "type": "object",
            "additionalProperties": true
          },
          "resistances": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          }
        }
      }
    },
    "mechanic": {
      "minWikilinks": 2,
      "description": "A core gameplay rule with formula, inputs, outputs, and edge_cases as required frontmatter fields.",
      "frontmatter_schema": {
        "required": [
          "formula",
          "inputs",
          "outputs",
          "edge_cases"
        ],
        "properties": {
          "formula": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "range": {
                  "type": "object",
                  "properties": {
                    "min": {
                      "type": "number"
                    },
                    "max": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          },
          "edge_cases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "system": {
      "minWikilinks": 2,
      "description": "A meta-system with controlled_entities, state_transitions, and progression nodes as required frontmatter fields.",
      "frontmatter_schema": {
        "required": [
          "controlled_entities",
          "state_transitions"
        ],
        "properties": {
          "controlled_entities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            }
          },
          "state_transitions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "from",
                "to",
                "trigger"
              ],
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "trigger": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "location": {
      "minWikilinks": 1,
      "description": "A playable map or location with map_layout, objectives, difficulty, and enemy_spawns as required frontmatter fields.",
      "frontmatter_schema": {
        "properties": {
          "biome": {
            "type": "string"
          },
          "connected_to": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            }
          },
          "spawns": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            }
          }
        }
      }
    },
    "npc": {
      "minWikilinks": 1,
