  "engine_candidates": [
    {
      "name": "Bevy",
      "language": "Rust",
      "pros": [
        "ECS architecture naturally maps tower-defense entity patterns (units, buildings, swarms)",
        "Deterministic by design; fixed-point crates (fixed, fixed-macro) integrate seamlessly",
        "Rust type system prevents entire desync-bug categories (integer overflow, memory unsafety)",
        "High-performance entity iteration; handles large infected swarms efficiently",
        "FixedUpdate schedule cleanly separates sim tick (20–30Hz) from render; scheduler enforces deterministic order"
      ],
      "cons": [
        "Steeper learning curve than visual engines",
        "Smaller ecosystem for RTS tools vs. Unity/Unreal",
        "Requires explicit care (no HashMap iteration in sim path, no float transcendentals)"
      ],
      "fit_score": 0.95,
      "links": [
        "https://bevyengine.org",
        "https://github.com/bevyengine/bevy"
      ]
    },
    {
      "name": "Godot 4.x",
      "language": "GDScript/C++",
      "pros": [
        "Excellent 2D support (tilemap, physics, collision native)",
        "Visual editor reduces friction for building-placement layout",
        "Open-source, free, strong indie RTS community",
        "GDScript approachable; C++ export for sim-path hot code",
        "Determinism achievable with SeededRNG + ordered processing"
      ],
      "cons": [
        "Physics engine defaults to float; major retrofit for fixed-point determinism",
        "Networking not built-in; lockstep is fully custom",
        "Scheduler less transparent than Bevy; deterministic order requires discipline",
        "Smaller corpus of deterministic-netcode patterns"
      ],
      "fit_score": 0.72,
      "links": [
        "https://godotengine.org",
        "https://docs.godotengine.org/en/stable/"
      ]
    },
    {
      "name": "LibGDX",
      "language": "Java",
      "pros": [
        "Purpose-built for games; no engine overhead",
        "JVM determinism mature; seeded Random stable across JVMs",
        "Strong performance on 2D entity-heavy games (tower-defense proven)",
        "Open-source; indie RTS examples in the wild",
        "Cross-platform deployment without runtime surprises"
      ],
      "cons": [
        "Java GC pauses break lockstep if not carefully tuned",
        "No built-in netcode; lockstep layer is fully custom",
        "Type safety relies on discipline, not language enforcement",
        "No visual editor; all placement is code-driven"
      ],
      "fit_score": 0.68,
      "links": [
        "https://libgdx.com",
        "https://github.com/libgdx/libgdx"
      ]
    },
    {
      "name": "Unreal Engine 5",
      "language": "C++",
      "pros": [
        "Industry-standard tooling and documentation",
        "High performance at extreme scale",
        "Replication Graph could theoretically adapt to lockstep"
      ],
      "cons": [
        "Severe overkill for 2D tower-defense RTS; massive bloat",
        "Determinism is not a design goal; float-based physics pervasive",
        "Team/compile-time overhead; solo/small-team overhead too high",
        "Netcode designed for client-server, not lockstep; major rework required"
      ],
      "fit_score": 0.35,
      "links": [
        "https://www.unrealengine.com",
        "https://docs.unrealengine.com"
      ]
    }
  ],
  "chosen_engine": {
    "name": "Bevy",
    "language": "Rust",
    "selected_from": "engine_candidates[1]",
    "selected_on": "2026-05-19",
    "networking_model": "deterministic lockstep",
    "architecture": "fixed-tick sim (20-30Hz) decoupled from interpolated render tick; only inputs cross the wire",
    "notes": "Determinism rules are binding on all Phase 2 sim-path code. See CLAUDE.md > 'Target engine' for the full rule set."
  }
