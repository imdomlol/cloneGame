      "frontmatter_schema": {
        "required": [
          "stats",
          "requirements",
          "tags"
        ],
        "properties": {
          "stats": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "integer"
              ]
            }
          },
          "requirements": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "integer",
                "string"
              ]
            }
          },
          "crafting": {
            "type": "object",
            "properties": {
              "recipe_id": {
                "type": "string"
              },
              "materials": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "qty"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "pattern": "^[a-z0-9_]+$"
                    },
                    "qty": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              },
              "station": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "skill": {
      "minWikilinks": 1,
      "description": "An ability with cost, cooldown, effects, and scaling fields.",
      "frontmatter_schema": {
        "required": [
          "cost",
          "cooldown",
          "effects",
          "scaling"
        ],
        "properties": {
          "cost": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "integer"
              ]
            }
          },
          "cooldown": {
            "type": "number",
            "minimum": 0
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "minItems": 1
          },
          "scaling": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "number",
                "string"
              ]
            }
          }
        }
      }
    },
    "quest": {
      "minWikilinks": 1,
