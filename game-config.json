      "frontmatter_schema": {
        "properties": {
          "role": {
            "type": "string"
          },
          "location": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "offers": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            }
          }
        }
      }
    },
    "organization": {
      "minWikilinks": 1,
      "description": "A faction or group with members, goals, lore, and affiliated_locations as required frontmatter fields."
    },
    "item": {
      "minWikilinks": 1,
