{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/skill.schema.json",
  "title": "Skill",
  "allOf": [{ "$ref": "_universal.schema.json" }],
  "type": "object",
  "required": ["cost", "cooldown", "effects", "scaling"],
  "properties": {
    "type": { "const": "skill" },
    "cost": {
      "type": "object",
      "additionalProperties": { "type": ["number", "integer"] }
    },
    "cooldown": { "type": "number", "minimum": 0 },
    "effects": {
      "type": "array",
      "items": { "type": "object" },
      "minItems": 1
    },
    "scaling": {
      "type": "object",
      "additionalProperties": { "type": ["number", "string"] }
    }
  }
}
