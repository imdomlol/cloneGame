{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/location.schema.json",
  "title": "Location",
  "allOf": [{ "$ref": "_universal.schema.json" }],
  "type": "object",
  "properties": {
    "type": { "const": "location" },
    "biome": { "type": "string" },
    "connected_to": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "spawns": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    }
  }
}
