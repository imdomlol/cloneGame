{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/system.schema.json",
  "title": "System",
  "allOf": [{ "$ref": "_universal.schema.json" }],
  "type": "object",
  "required": ["controlled_entities", "state_transitions"],
  "properties": {
    "type": { "const": "system" },
    "controlled_entities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
    },
    "state_transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "trigger"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "trigger": { "type": "string" }
        }
      }
    }
  }
}
