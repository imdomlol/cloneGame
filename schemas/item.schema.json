{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/item.schema.json",
  "title": "Item",
  "allOf": [{ "$ref": "_universal.schema.json" }],
  "type": "object",
  "required": ["stats", "requirements", "tags"],
  "properties": {
    "type": { "const": "item" },
    "stats": {
      "type": "object",
      "additionalProperties": { "type": ["number", "integer"] }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": { "type": ["number", "integer", "string"] }
    },
    "crafting": {
      "type": "object",
      "properties": {
        "recipe_id": { "type": "string" },
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "qty"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
              "qty": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "station": { "type": "string" }
      }
    }
  }
}
