{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/enemy.schema.json",
  "title": "Enemy",
  "allOf": [{ "$ref": "_universal.schema.json" }],
  "type": "object",
  "required": ["stats", "loot_table", "ai_profile", "resistances"],
  "properties": {
    "type": { "const": "enemy" },
    "stats": {
      "type": "object",
      "additionalProperties": { "type": ["number", "integer"] }
    },
    "loot_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "chance"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "chance": { "type": "number", "minimum": 0, "maximum": 1 },
          "min": { "type": "integer", "minimum": 0 },
          "max": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "ai_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "resistances": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    }
  }
}
