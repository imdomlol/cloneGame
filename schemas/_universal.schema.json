{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloneGame.local/schemas/_universal.schema.json",
  "title": "Universal Vault Frontmatter",
  "description": "Fields required on every vault file regardless of type. Per-type schemas extend this via allOf.",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "subtype",
    "source_url",
    "source_revision",
    "extracted_at",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "snake_case, unique within vault"
    },
    "name": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["item", "skill", "enemy", "mechanic", "location", "npc", "quest", "system", "concept"]
    },
    "subtype": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "source_revision": {
      "type": ["string", "integer"],
      "description": "MediaWiki revision id. The API returns it as an integer; older string-coerced records are still accepted."
    },
    "extracted_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
      "description": "Must mirror every [[wikilink]] in the body."
    }
  }
}
