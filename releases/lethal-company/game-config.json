  "engine_candidates": [
    {
      "name": "Unity",
      "language": "C#",
      "pros": [
        "Strong fit for a first-person 3D co-op game with many interactable item pages: scrap, store items, weapons, ship furniture, and ship upgrades.",
        "Good tooling for rapid content iteration across the large set of gameplay mechanics, entities, destinations, and versioned live updates.",
        "Broad networking ecosystem for multiplayer session flow, synchronized pickups, enemy AI, and co-op traversal."
      ],
      "cons": [
        "Deterministic simulation is not automatic, so replayable enemy behavior and item interactions need deliberate engineering.",
        "Can become complex to maintain if the project grows into a heavy content pipeline with many data-driven categories."
      ],
      "fit_score": 0.92,
      "links": [
        "https://unity.com/"
      ]
    },
    {
      "name": "Unreal Engine",
      "language": "C++",
      "pros": [
        "Very strong for atmospheric 3D presentation, which fits a game centered on destinations, entities, hazards, and indoor/outdoor encounters.",
        "Good support for authoritative multiplayer architecture and replication for co-op gameplay.",
        "Robust tooling for complex AI, physics, and first-person interaction systems."
      ],
      "cons": [
        "Heavier workflow than needed for a smaller content-heavy indie-style game.",
        "Content iteration and data-driven item catalogs can be more cumbersome than in lighter engines."
      ],
      "fit_score": 0.86,
      "links": [
        "https://www.unrealengine.com/"
      ]
    },
    {
      "name": "Godot Engine",
      "language": "GDScript or C#",
      "pros": [
        "Flexible for building data-driven systems for scrap, entities, mechanics, and destination content.",
        "Faster to prototype than heavier AAA engines, which helps when iterating on many wiki-defined gameplay rules.",
        "Open workflow can suit a compact team building a clone from structured wiki data."
      ],
      "cons": [
        "Less proven for large-scale 3D multiplayer and complex AI-heavy games than Unity or Unreal.",
        "Tooling and ecosystem depth are weaker for demanding networking and production-scale content pipelines."
      ],
      "fit_score": 0.68,
      "links": [
        "https://godotengine.org/"
      ]
    },
    {
      "name": "Bevy",
      "language": "Rust",
      "pros": [
        "ECS architecture can map cleanly to many entity categories, hazards, items, and mechanics pulled from wiki data.",
        "Rust offers strong safety properties and can support deterministic gameplay code if carefully designed."
      ],
      "cons": [
        "Still immature for turnkey 3D multiplayer, editor tooling, and content authoring compared with mainstream game engines.",
        "Would require much more custom work for UI, level authoring, networking, and asset pipeline needs."
      ],
      "fit_score": 0.54,
      "links": [
        "https://bevyengine.org/"
      ]
    }
  ],
  "chosen_engine": {
    "name": "Bevy",
    "language": "Rust",
    "selected_from": "engine_candidates[3]",
    "selected_on": "2026-06-07",
    "networking_model": "deterministic lockstep",
    "architecture": "fixed-tick sim (20-30Hz) decoupled from interpolated render tick; only inputs cross the wire",
    "notes": "Selected for Lethal Company target-game pipeline validation. See docs/MEMORY.md.",
    "module_registration": {
      "aggregator": "{dir}/mod.rs",
      "declaration": "pub mod {stem};",
      "crate_root": "src/lib.rs"
    },
    "entrypoint": {
      "aggregator_file": "src/app_plugins.rs",
      "aggregator_module": "app_plugins",
      "tuple_chunk_size": 14,
      "main_file": "src/main.rs",
      "excluded_plugins": {
        "GameStateMachinePlugin": "Generated plugin adds StatesPlugin which DefaultPlugins already includes; smoke test uses MinimalPlugins so this went undetected. Will be fixed when bevy.md S1 rule update flows through next regen."
      }
    },
    "systems": [
      {
        "name": "game_state_machine",
        "description": "Tracks and transitions between menu, playing, paused, win, and lose game states.",
        "depends_on": [],
        "produces": [
          "game_state_changed",
          "game_won",
          "game_lost"
        ]
      },
      {
        "name": "input_handler",
        "description": "Maps keyboard and mouse input to player actions like movement, weapon firing, and item pickup.",
        "depends_on": [
          "weapon_pages"
        ],
        "produces": [
          "player_input",
          "action_triggered"
        ]
      },
      {
        "name": "hud",
        "description": "Renders UI showing quota progress, scrap inventory, equipped weapons, active upgrades, and time remaining.",
        "depends_on": [
          "scrap_items",
          "weapon_pages",
          "ship_upgrade_pages"
        ],
        "produces": []
      },
      {
        "name": "entity_spawner",
        "description": "Spawns hostile creatures on the map based on elapsed time, location, and difficulty.",
        "depends_on": [
          "entity_pages",
          "indoor_entity_pages",
          "outdoor_entity_pages",
          "daytime_entity_pages"
        ],
        "produces": [
          "entity_spawned",
          "wave_triggered"
        ]
      },
      {
        "name": "scrap_economy",
        "description": "Tracks collected scrap items, manages player inventory, and updates progress toward the profit quota.",
        "depends_on": [
          "scrap_items"
        ],
        "produces": [
          "scrap_collected",
          "quota_progress",
          "inventory_changed"
        ]
      },
      {
        "name": "combat_system",
        "description": "Resolves weapon attacks against creatures, applies damage, and handles creature death.",
        "depends_on": [
          "weapon_pages",
          "entity_pages",
          "harmless_entity_pages"
        ],
        "produces": [
          "damage_applied",
          "creature_killed",
          "weapon_fired"
        ]
      },
      {
        "name": "facility_timer",
        "description": "Manages time pressure on exploration; triggers entity spawning waves and enforces mission time limits.",
        "depends_on": [
          "gameplay_mechanics"
        ],
        "produces": [
          "time_elapsed",
          "time_warning",
          "time_expired"
        ]
      },
      {
        "name": "hazard_system",
        "description": "Detects and triggers environmental hazards, applies damage when players interact with them.",
        "depends_on": [
          "map_hazard_pages"
        ],
        "produces": [
          "hazard_triggered",
          "hazard_damage"
        ]
      },
      {
        "name": "creature_ai",
        "description": "Controls hostile creature behavior including movement, aggression, and targeting of nearby players.",
        "depends_on": [
