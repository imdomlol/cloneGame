# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Python packaging and virtual environments
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Project generated outputs and local caches
vault/
.phase1_cache/
# Phase 0 proposals are regenerated on every run; the source of truth is game-config.json
*.proposed.json
# Phase 2 vector index (Chroma). The build/ directory (above) already covers build/repomix-output.xml.
chroma/
.chroma/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
!.env.*.example
*.local
*.pem
*.key
*.crt
*.p12
*.pfx
.claude/settings.local.json

# Logs, temporary files, and local databases
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*.sqlite
*.sqlite3
*.db

# Editor and OS files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Rust build artifacts (game/target/, etc.). Cargo.lock IS committed for the
# game binary so the regression anchor is reproducible.
target/

# Node/tooling artifacts if frontend tooling is added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
